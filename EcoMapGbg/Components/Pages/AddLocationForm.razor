@using EcoMapGbg.Models.DTO
@inject ILocationService LocationService

<EditForm Model="newLocation" OnValidSubmit="HandleSubmit" FormName="AddLocationForm">
    <DataAnnotationsValidator />
    <ValidationSummary class="alert alert-danger mb-3" />

    <div class="mb-3">
        <label class="form-label">🏪 Name</label>
        <InputText @bind-Value="newLocation.Name" class="form-control" placeholder="e.g., Green Café" />
    </div>

    <div class="mb-3">
        <label class="form-label">📍 Address</label>
        <InputText @bind-Value="newLocation.Address" class="form-control" placeholder="e.g., Vasagatan 10" />
    </div>

    <div class="mb-3">
        <label class="form-label">📂 Category</label>
        <InputSelect @bind-Value="newLocation.Type" class="form-select">
            <option value="">Select category...</option>
            <option value="SecondHand">🛍️ Second-hand Shop</option>
            <option value="VeganCafe">🌱 Vegan Café</option>
            <option value="RecyclingCenter">♻️ Recycling Center</option>
            <option value="RepairCafe">🔧 Repair Café</option>
            <option value="Garden">☀️ Community Garden</option>
        </InputSelect>
    </div>

    <div class="mb-3">
        <label class="form-label">📝 Description</label>
        <InputTextArea @bind-Value="newLocation.Description" class="form-control" rows="3" />
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">🌐 Latitude</label>
            <InputNumber @bind-Value="newLocation.Latitude" class="form-control" step="0.000001" />
        </div>
        <div class="col-md-6">
            <label class="form-label">🌐 Longitude</label>
            <InputNumber @bind-Value="newLocation.Longitude" class="form-control" step="0.000001" />
        </div>
    </div>

    <div class="form-check mt-3">
        <InputCheckbox @bind-Value="newLocation.IsFree" class="form-check-input" />
        <label class="form-check-label">🆓 Free to use</label>
    </div>

    <button type="submit" class="btn btn-success mt-4">🌿 Submit</button>


</EditForm>

@code {
    [Parameter] public EventCallback OnSuccess { get; set; }

    [SupplyParameterFromForm]
    private CreateLocationRequest newLocation { get; set; } = new() { Tags = new List<string>() };
    
    private string message = string.Empty;

    protected override void OnInitialized()
    {
        newLocation ??= new() { Tags = new List<string>() };
    }

    private async Task HandleSubmit()
    {
        try
        {
            var result = await LocationService.CreateLocationAsync(newLocation);
            message = $"✅ '{result.Name}' was added successfully!";
            
            // Reset form
            newLocation = new() { Tags = new List<string>() };
            StateHasChanged();
            
            await OnSuccess.InvokeAsync();
        }
        catch (Exception ex)
        {
            message = $"❌ Error: {ex.Message}";
        }
    }
}