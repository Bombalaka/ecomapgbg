# Copy to .env in this folder (repo root). Never commit .env.

MONGO_USERNAME=root
MONGO_PASSWORD=example
MONGO_DB=ecomapgbg

# Atlas — use quotes because the URI contains & characters
ConnectionStrings__MongoDB="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/ecomapgbg?retryWrites=true&w=majority"
