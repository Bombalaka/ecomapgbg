# Mapbox token (optional) - without it, Leaflet + OpenStreetMap is used (free, no signup)
# Get a free token at https://mapbox.com for nicer maps
# VITE_MAPBOX_TOKEN=

# Optional: looping MP4 for the / landing page background (muted). Leave empty for gradient-only.
# Example: a short file you host in public/: /videos/landing-loop.mp4
# VITE_LANDING_VIDEO_URL=

# Optional: API URL for dev (default: /api - uses Vite proxy)
# VITE_API_URL=http://localhost:5202/api
